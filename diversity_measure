import json
import re
from collections import Counter
import numpy as np




#JSON-Pfad
path = "talkshow_results_topics.jsonl"

#Filter nach Show oder Sender – Falls gewünscht eintragen. Andernfalls auslassen.
show = ""
sender = ""




# Themenzähler (mit JSONL-Parser)
def get_topic_counts(filepath: str) -> dict:
    topics = []
    with open(filepath, "r", encoding="utf-8") as f:
        for line in f:
            data = json.loads(line)
            if "topic" not in data: continue
            if show and data.get("show") != show: continue  # Show-Filter
            if sender and data.get("sender") != sender: continue  # Sender-Filter
            topics.append(data["topic"])
    return Counter(topics)

# Themenzähler ausgeben lassen
for topic, count in sorted(counts.items(), key=lambda x: -x[1]):
    print(f"{topic}: {count}")




#Diversität berechnen mit SEI (Themen-Balance)
counts = get_topic_counts(path)
total = sum(counts.values())
proportions = {k: v / total for k, v in counts.items()}

# Shannon Diversity Index (SDI)
sdi = -sum(p * np.log(p) for p in proportions.values() if p > 0)

# Shannon Evenness Index (SEI)
n_topics = len(counts)
sei = sdi / np.log(n_topics)




# Ausgabe
print(f"Ausgewertete Einheiten: {total}")
print(f"Anzahl Themen: {n_topics}")
print(f"SDI:           {sdi:.4f}")
print(f"SEI:           {sei:.4f}")
print()
print("Themenanteile (absteigend):")
for topic, p in sorted(proportions.items(), key=lambda x: -x[1]):
    print(f"  {topic:<20} {p*100:5.1f}%")
